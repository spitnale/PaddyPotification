# ---- Dependencies ----
node_modules/
/.pnp
.pnp.js

# ---- Next.js ----
/.next/
/out/
next-env.d.ts

# ---- Production build / server bundle ----
/build
/dist
src-tauri/server-bundle/

# ---- Tauri (Rust) ----
src-tauri/target/
src-tauri/gen/
# Large native sidecar binaries — fetched/built locally, not committed
src-tauri/binaries/

# ---- Runtime data ----
# Local ended-session cache written to the home dir at runtime
*.local

# ---- Environment / secrets ----
.env
.env.*
!.env.example

# ---- Editor / IDE ----
.idea/
.vscode/
*.iml

# ---- Claude Code ----
# Local assistant config — never for the public repo
.claude/
CLAUDE.md
CLAUDE.local.md

# ---- Private / local-only assets ----
# Design mockups and anything you don't want in the public repo
private/

# ---- macOS ----
.DS_Store
.AppleDouble
.LSOverride

# ---- Logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
