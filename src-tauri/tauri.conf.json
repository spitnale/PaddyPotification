{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Paddy Potification",
  "version": "0.1.0",
  "identifier": "com.spitnale.paddy",
  "build": {
    "frontendDist": "../tauri-shell"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Paddy",
        "label": "main",
        "width": 420,
        "height": 900,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "shortDescription": "Live Claude Code session board",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "iOS": {
      "minimumSystemVersion": "14.0"
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
